# Server Configuration
PORT=5000

# Database Configuration
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=credit_score_db

# Email / SMTP Configuration
# Set these to send real emails. If left blank, the app falls back to Ethereal mock email testing.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
# Note: For Gmail, you must generate a 16-character App Password (requires 2-Step Verification enabled)
SMTP_PASS=your-gmail-app-password
SMTP_FROM=CredScore <your-email@gmail.com>
